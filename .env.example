# Speechmatics API Key (Speech-to-Text)
SPEECHMATICS_KEY=your_speechmatics_api_key_here

# Vogent API Key (Text-to-Speech)
VOGENT_API_KEY=your_vogent_api_key_here

# Google Gemini API Key (Grammar Coaching AI)
# Get from: https://ai.google.dev/
# Using direct REST API: gemini-flash-latest model
GEMINI_API_KEY=your_gemini_api_key_here

# Server Configuration
PORT=5000
NODE_ENV=development
